SECRET_KEY=change-this-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Base de datos (servicio Docker "db") ────────────────────────────────────
DB_HOST=db
DB_PORT=3306
DB_USER=pbxuser
DB_PASSWORD=pbx_pass
DB_NAME=asterisk_gui
DB_ROOT_PASSWORD=pbx_root_pass

# ── AMI — Asterisk corre en el HOST, no en Docker ───────────────────────────
# Docker resuelve "host.docker.internal" al gateway del host (el servidor real)
AMI_HOST=host.docker.internal
AMI_PORT=5038
AMI_USER=admin
AMI_PASSWORD=secret

# ── ARI — igual, Asterisk en el host ────────────────────────────────────────
ARI_HOST=host.docker.internal
ARI_PORT=8088
ARI_USER=asterisk
ARI_PASSWORD=asterisk

# ── Rutas montadas como volúmenes ───────────────────────────────────────────
ASTERISK_CONFIG_PATH=/etc/asterisk
RECORDINGS_PATH=/var/spool/asterisk/monitor
SOUNDS_PATH=/var/lib/asterisk/sounds/custom
